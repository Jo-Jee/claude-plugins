{
  "description": "Re-pins the statusline plugin's absolute path in settings.json each session.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/sync.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
